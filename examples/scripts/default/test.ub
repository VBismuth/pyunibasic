// Encoding: UTF-8

//! @title test.ub
//! @desc this is a simple assert testing

// $SUBSET "default"
$PRELUDE

LOADPKG $LIB("std/testing"), [!ASSERT]

MAINFN % UINT8 {

    ASSERT 3 + 4 * 2 ^ (4 / 2) - 4 * (3 - 1) == 11
    ASSERT 11 ~= '11'
    ASSERT "Hello, " == "Hello, "
    ASSERT "\"Hello, " ~= "'Hello, \'"

    PRINTLN '\'This is a "TEST"\''

    RETURN 0
}
