// Кодировка: UTF-8

//! @title test.ub
//! @desc это просто тест утверждения

$? "ru_ru"

ЗАГРУЗИПКТ $БИБЛ("std/fmt"), [!ВЫВОДНС]
ЗАГРУЗИПКТ $БИБЛ("std/testing"), [!УТВЕРДИ]

ОСНОВНАЯФН % БЦЕЛ8 {

    УТВЕРДИ 3 + 4 * 2 ^ (4 / 2) - 4 * (3 - 1) == 11
    УТВЕРДИ 11 ~= '11'
    УТВЕРДИ "Hello, " == "Hello, "
    УТВЕРДИ "\"Hello, " ~= "'Hello, \'"

    ВЫВОДНС '\'This is a "TEST"\''

    ВЕРНИ 0
}
