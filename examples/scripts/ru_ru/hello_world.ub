// Кодировка: UTF-8

$? "ru_ru"
$ПРЕЛЮДИЯ
/// чтобы не писать
ЗАГРУЗИПКТ $БИБЛ("std/fmt"), [!ВЫВОДНС,
                              !ВЫВОДФНС,
                              !ВЫВОД,
                              !ВВОД,
                              !ЖДИ] \\\

ОСНОВНАЯФН {
    ВЫВОДНС "Введите ваше имя: "
    ВВОД  // ВВОД $РЕЗ - сохранает ввод в переменную
          // Просто ВВОД или ВВОД $РЕЗ - эквивалентны
    ВЫВОДНС
    ВЫВОДФНС "Привет, {$РЕЗ[STR]:~1}!"
    ЖДИ
}
